{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin/dashboard",
      "regex": "^/admin/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/dashboard(?:/)?$"
    },
    {
      "page": "/admin/manage-course",
      "regex": "^/admin/manage\\-course(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/manage\\-course(?:/)?$"
    },
    {
      "page": "/admin/manage-leads",
      "regex": "^/admin/manage\\-leads(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/manage\\-leads(?:/)?$"
    },
    {
      "page": "/admin/reel",
      "regex": "^/admin/reel(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/reel(?:/)?$"
    },
    {
      "page": "/api/auth/google",
      "regex": "^/api/auth/google(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/google(?:/)?$"
    },
    {
      "page": "/api/auth/google/callback",
      "regex": "^/api/auth/google/callback(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/google/callback(?:/)?$"
    },
    {
      "page": "/cancellation-policy",
      "regex": "^/cancellation\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cancellation\\-policy(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/privacy-policy",
      "regex": "^/privacy\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy\\-policy(?:/)?$"
    },
    {
      "page": "/refurnd-policy",
      "regex": "^/refurnd\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/refurnd\\-policy(?:/)?$"
    },
    {
      "page": "/shiping-policy",
      "regex": "^/shiping\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/shiping\\-policy(?:/)?$"
    },
    {
      "page": "/signup",
      "regex": "^/signup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/signup(?:/)?$"
    },
    {
      "page": "/terms-and-condition",
      "regex": "^/terms\\-and\\-condition(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms\\-and\\-condition(?:/)?$"
    }
